{
  "version": "7.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-lifeline/ember-lifeline.git"
  },
  "license": "MIT",
  "contributors": [
    "Robert Jackson <me@rwjblue.com>",
    "Steve Calvert <steve.calvert@gmail.com>"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --recursive build",
    "docs:readme": "cp ./README.md ./packages/ember-lifeline/README.md",
    "lint": "pnpm --recursive lint",
    "prepare": "pnpm --filter ember-lifeline prepare",
    "test": "pnpm --recursive test"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001482"
  },
  "devDependencies": {
    "@release-it-plugins/workspaces": "^3.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "release-it": "^15.10.3",
    "release-it-lerna-changelog": "^5.0.0",
    "release-plan": "^0.18.0"
  },
  "packageManager": "pnpm@8.15.9",
  "volta": {
    "node": "24.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "overrides": {
      "@ember/test-helpers@^5>@ember/test-waiters": "^4.0.0",
      "cheerio": "1.0.0-rc.12",
      "favicons": "5.3.0",
      "testem": "~3.10.1"
    }
  },
  "release-it": {
    "plugins": {
      "release-it-lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      },
      "@release-it-plugins/workspaces": true
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    },
    "npm": false
  }
}
